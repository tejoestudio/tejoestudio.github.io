{
  "name": "tejoestudio",
  "version": "1.0.0",
  "description": "Link aggregator and press kit platform for Tejo Estúdio",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "node build.js",
    "watch": "chokidar \"src/**/*\" -c \"npm run build\"",
    "serve": "browser-sync start --server \"dist\" --files \"dist/**/*\" --no-notify --port 3000",
    "dev": "npm-run-all build --parallel watch serve"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaelfeitosa/tejoestudio.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/kaelfeitosa/tejoestudio/issues"
  },
  "homepage": "https://github.com/kaelfeitosa/tejoestudio#readme",
  "dependencies": {
    "handlebars": "^4.7.9"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "chokidar-cli": "^3.0.0",
    "npm-run-all": "^4.1.5"
  }
}

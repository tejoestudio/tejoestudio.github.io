          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/screenshots/vem_exu_screenshot_09.jpg" alt="{{{presskit.alt_screenshot_09}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/screenshots/vem_exu_screenshot_10.jpg" alt="{{{presskit.alt_screenshot_10}}}"></figure>

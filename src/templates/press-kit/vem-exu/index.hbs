          </div>
          <div class="pk-clip-card">
            <video muted loop playsinline preload="metadata">
              <source src="{{{base_path}}}press-kit/vem-exu/02_media/video_clips/vem_exu_clip_misc_06.mp4" type="video/mp4">
            </video>
          </div>
          <div class="pk-clip-card">
            <video muted loop playsinline preload="metadata">
              <source src="{{{base_path}}}press-kit/vem-exu/02_media/video_clips/vem_exu_clip_misc_07.mp4" type="video/mp4">
            </video>
          </div>
          <div class="pk-clip-card">
            <video muted loop playsinline preload="metadata">
              <source src="{{{base_path}}}press-kit/vem-exu/02_media/video_clips/vem_exu_clip_misc_08.mp4" type="video/mp4">
            </video>
          </div>
        </div>
      </section>

      <section class="pk-media-block" aria-labelledby="screenshots-titulo">
        <header class="pk-media-heading">
          <h3 id="screenshots-titulo">Screenshots</h3>
          <button data-download="screenshots">{{{presskit.download_btn}}}</button>
        </header>
        <div class="pk-gallery pk-gallery-screens">
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/screenshots/vem_exu_screenshot_01.jpg" alt="{{{presskit.alt_screenshot_01}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/screenshots/vem_exu_screenshot_02.jpg" alt="{{{presskit.alt_screenshot_02}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/screenshots/vem_exu_screenshot_03.jpg" alt="{{{presskit.alt_screenshot_03}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/screenshots/vem_exu_screenshot_04.jpg" alt="{{{presskit.alt_screenshot_04}}}"></figure>

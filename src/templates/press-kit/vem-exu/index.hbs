          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/gifs/vem_exu_gif_misc_05.gif" alt="{{{presskit.alt_gif_05}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/gifs/vem_exu_gif_misc_06.gif" alt="{{{presskit.alt_gif_06}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/gifs/vem_exu_gif_misc_07.gif" alt="{{{presskit.alt_gif_07}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/gifs/vem_exu_gif_misc_08.gif" alt="{{{presskit.alt_gif_08}}}"></figure>
        </div>
      </section>

      <section class="pk-media-block" aria-labelledby="clips-titulo">
        <header class="pk-media-heading">
          <h3 id="clips-titulo">{{{presskit.clips_title}}}</h3>
          <button data-download="clips">{{{presskit.download_clips}}}</button>
        </header>
        <p style="color: var(--pk-muted); font-size: 0.9rem;">{{{presskit.clips_desc}}}</p>
        <div class="pk-gallery pk-gallery-clips">
          <div class="pk-clip-card">
            <video muted loop playsinline preload="metadata">
              <source src="{{{base_path}}}press-kit/vem-exu/02_media/video_clips/vem_exu_clip_misc_01.mp4" type="video/mp4">

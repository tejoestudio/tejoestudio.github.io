      <section class="pk-media-block" aria-labelledby="keyart-titulo">
        <header class="pk-media-heading">
          <h3 id="keyart-titulo">{{{presskit.keyart_title}}}</h3>
          <button data-download="keyart">{{{presskit.download_btn}}}</button>
        </header>
        <div class="pk-gallery pk-gallery-keyart">
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/keyart/vem_exu_keyart_01.png" alt="{{{presskit.alt_keyart_01}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/keyart/vem_exu_keyart_02.png" alt="{{{presskit.alt_keyart_02}}}"></figure>
        </div>
      </section>

      <section class="pk-media-block" aria-labelledby="logos-titulo">
        <header class="pk-media-heading">
          <h3 id="logos-titulo">{{{presskit.logos_title}}}</h3>
          <button data-download="logos">{{{presskit.download_btn}}}</button>
        </header>
        <div class="pk-gallery pk-gallery-logos">
          <figure class="pk-logo-item"><img src="{{{base_path}}}press-kit/vem-exu/03_branding/logos/vem_exu_logo_black.png" alt="{{{presskit.alt_logo_exu_black}}}">
          </figure>
          <figure class="pk-logo-item pk-bg-dark"><img src="{{{base_path}}}press-kit/vem-exu/03_branding/logos/vem_exu_logo_white.png"
              alt="{{{presskit.alt_logo_exu_white}}}"></figure>
          <figure class="pk-logo-item"><img src="{{{base_path}}}press-kit/vem-exu/03_branding/studio/tejo_logo_black.png"
              alt="{{{presskit.alt_logo_tejo_black}}}"></figure>
          <figure class="pk-logo-item pk-bg-dark"><img src="{{{base_path}}}press-kit/vem-exu/03_branding/studio/tejo_logo_white.png"
              alt="{{{presskit.alt_logo_tejo_white}}}"></figure>
        </div>
      </section>

      <section class="pk-media-block" aria-labelledby="personagens-titulo">
        <header class="pk-media-heading">
          <h3 id="personagens-titulo">{{{presskit.characters_title}}}</h3>
          <button data-download="characters">{{{presskit.download_btn}}}</button>
        </header>
        <div class="pk-gallery pk-gallery-banners">
          <figure><img src="{{{base_path}}}press-kit/vem-exu/03_branding/characters/vem_exu_character_full_01.png" alt="{{{presskit.alt_character_01}}}">
          </figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/03_branding/characters/vem_exu_character_full_02.png" alt="{{{presskit.alt_character_02}}}">
          </figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/03_branding/characters/vem_exu_character_full_03.png" alt="{{{presskit.alt_character_03}}}">
          </figure>
        </div>
      </section>
      <section class="pk-media-block" aria-labelledby="eventos-titulo">
        <header class="pk-media-heading">
          <h3 id="eventos-titulo">{{{presskit.events_title}}}</h3>
          <button data-download="events">{{{presskit.download_btn}}}</button>
        </header>
        <p style="color: var(--pk-muted); font-size: 0.9rem; margin-bottom: 1rem;">
          {{{presskit.events_desc}}}
        </p>
        <div class="pk-gallery pk-gallery-events">
          <!-- SANA -->
          <figure><img src="{{{base_path}}}images/records/sana_2026_1_01.jpeg" alt="{{{presskit.alt_event_sana_01}}}"></figure>
          <figure><img src="{{{base_path}}}images/records/sana_2026_1_02.jpeg" alt="{{{presskit.alt_event_sana_02}}}"></figure>

          <!-- Feira do Conhecimento -->
          <figure><img src="{{{base_path}}}images/records/feira_do_conhecimento_01.jpeg" alt="{{{presskit.alt_event_feira_01}}}"></figure>
          <figure><img src="{{{base_path}}}images/records/feira_do_conhecimento_02.jpeg" alt="{{{presskit.alt_event_feira_02}}}"></figure>

          <!-- Escolas e Comunidade -->
          <figure><img src="{{{base_path}}}images/records/escola_torres_de_melo_01.jpg" alt="{{{presskit.alt_event_escola_01}}}"></figure>
        </div>
      </section>
    </section>



    <section id="equipe" class="pk-section" aria-labelledby="equipe-titulo">
      <header class="pk-section-heading">
        <h2 id="equipe-titulo">{{{presskit.nav_team}}}</h2>
      </header>

      <div class="pk-team-list">
        {{#each presskit.team}}
        <div class="pk-team-item">
          <h3>{{{name}}}</h3>
          <p class="pk-role">{{{role}}}</p>
          {{#if desc}}
          <p>{{{desc}}}</p>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </section>



    <section id="extras" class="pk-section" aria-labelledby="extras-titulo">
      <header class="pk-section-heading" style="display:flex; align-items:baseline; justify-content:space-between; gap:1rem;">
        <h2 id="extras-titulo">{{{presskit.stickers_title}}}</h2>
        <button data-download="stickers">{{{presskit.download_btn}}}</button>
      </header>
      <p>{{{presskit.stickers_desc}}}</p>
      <div class="pk-sticker-grid">
        <img src="{{{base_path}}}press-kit/vem-exu/05_extras/stickers/vem_exu_sticker_color_01.png" alt="{{{presskit.alt_sticker_color_01}}}">

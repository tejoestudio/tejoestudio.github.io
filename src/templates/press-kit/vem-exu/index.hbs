          <button data-download="gifs">{{{presskit.download_btn}}}</button>
        </header>
        <div class="pk-gallery pk-gallery-gifs">
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/gifs/vem_exu_gif_misc_01.gif" alt="{{{presskit.alt_gif_01}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/gifs/vem_exu_gif_misc_02.gif" alt="{{{presskit.alt_gif_02}}}"></figure>
          <figure><img src="{{{base_path}}}press-kit/vem-exu/02_media/gifs/vem_exu_gif_misc_03.gif" alt="{{{presskit.alt_gif_03}}}"></figure>

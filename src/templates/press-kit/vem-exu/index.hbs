<!DOCTYPE html>
<html lang="{{lang}}">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{presskit.page_title}}</title>
  <meta name="description"
    content="{{presskit.meta_description}}">
  <meta name="author" content="Tejo Estúdio">
  <link rel="canonical" href="{{site_url}}{{canonical_path}}">
  <meta property="og:title" content="{{presskit.page_title}}">
  <meta property="og:description"
    content="{{presskit.meta_og_description}}">
  <meta property="og:type" content="website">
  <meta property="og:image" content="{{site_url}}press-kit/vem-exu/02_media/keyart/vem_exu_keyart_01.png">
  <link rel="icon" type="image/png" href="{{{base_path}}}images/tejo_icon.png">
  <link rel="stylesheet" href="{{{base_path}}}css/tejo-base.css">
  <link rel="stylesheet" href="{{{base_path}}}press-kit/vem-exu/presskit.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js" defer></script>
  <script src="{{{base_path}}}press-kit/vem-exu/presskit-downloads.js" defer></script>
  {{> partials/lang_redirect}}
</head>

<body>
  <a class="pk-skip-link" href="#conteudo">{{presskit.skip_content}}</a>

  <header class="pk-topbar">
    <div class="pk-topbar-inner">
      <a class="pk-wordmark" href="{{{language_path}}}index.html">&larr; {{presskit.back_home}}</a>
      <nav class="pk-nav" aria-label="{{presskit.aria_nav_presskit}}">
        <a href="#quick-facts">{{presskit.nav_summary}}</a>
        <a href="#sobre-o-jogo">{{presskit.nav_about}}</a>
        <a href="#para-publicacao">{{presskit.nav_publish}}</a>
        <a href="#media">{{presskit.nav_media}}</a>
        <a href="#equipe">{{presskit.nav_team}}</a>
        <a href="#contato">{{presskit.nav_contact}}</a>

      <div class="tejo-lang-switcher-container">
        {{#each other_langs}}
        <a href="{{{link}}}" class="tejo-lang-switcher" aria-label="{{aria}}" onclick="if(window.tejoSetLang){ window.tejoSetLang('{{code}}'); return false; }">
          {{label}}
        </a>
        {{/each}}
      </div>
      <button class="tejo-btn primary pk-nav-cta" data-download="full">{{presskit.download_full}}</button>
      </nav>
    </div>
  </header>

  <main id="conteudo" class="pk-shell">
    <section id="topo" class="pk-hero" aria-labelledby="pk-titulo">
      <div class="pk-hero-copy">
        <p class="pk-kicker">Press Kit</p>
        <h1 id="pk-titulo">Vem, Exu</h1>
        <p class="pk-lead">
          {{presskit.hero_lead}}
        </p>
        <p class="pk-sublead">
          {{presskit.hero_subtitle}}.
        </p>
        <nav class="pk-actions" aria-label="{{presskit.aria_main_actions}}">
          <a class="tejo-btn primary" href="https://play.google.com/store/apps/details?id=com.tejoestudio.exu"
            target="_blank" rel="noopener">{{presskit.hero_btn_play}}</a>

          <a class="tejo-btn secondary" href="#">
            {{presskit.hero_btn_wishlist}}
          </a>
        </nav>

        <p class="pk-caption">
          {{{presskit.hero_caption}}}
        </p>
      </div>

      <figure class="pk-hero-figure">
        <img src="{{{base_path}}}press-kit/vem-exu/02_media/keyart/vem_exu_keyart_01.png" alt="{{{presskit.alt_keyart_official}}}">
      </figure>
    </section>


    <section id="quick-facts" class="pk-section" aria-labelledby="facts-titulo">
      <header class="pk-section-heading">
        <h2 id="facts-titulo">{{presskit.nav_summary}}</h2>
      </header>
      <dl class="pk-facts-list">
        <div>
          <dt>{{presskit.fact_name}}</dt>
          <dd>Vem, Exu</dd>
        </div>
        <div>
          <dt>{{presskit.fact_genre}}</dt>
          <dd>{{presskit.fact_genre_val}}</dd>
        </div>
        <div>
          <dt>{{presskit.fact_price}}</dt>
          <dd>{{presskit.fact_price_val}}</dd>
        </div>
        <div>
          <dt>{{presskit.fact_platforms}}</dt>
          <dd>{{presskit.fact_platforms_val}}</dd>
        </div>
        <div>
          <dt>{{presskit.fact_duration}}</dt>
          <dd>{{presskit.fact_duration_val}}</dd>
        </div>
        <div>
          <dt>{{presskit.fact_language}}</dt>
          <dd>{{presskit.fact_language_val}}</dd>
        </div>
        <div>
          <dt>{{presskit.fact_start}}</dt>
          <dd>2024</dd>
        </div>
        <div>
          <dt>{{presskit.fact_fans}}</dt>
          <dd>Florence, Journey, GRIS</dd>
        </div>
        <div>
          <dt>{{presskit.fact_engine}}</dt>
          <dd>Godot</dd>
        </div>
        <div>
          <dt>{{presskit.fact_status}}</dt>
          <dd>{{presskit.fact_status_val}}</dd>
        </div>
        <div>
          <dt>{{presskit.nav_contact}}</dt>
          <dd>tejoestudio@gmail.com</dd>
        </div>
      </dl>
    </section>

    <section id="trailer" class="pk-section" aria-labelledby="trailer-titulo">
      <header class="pk-section-heading">
        <h2 id="trailer-titulo">{{presskit.trailer}}</h2>
      </header>
      <figure class="pk-video-frame">
        <iframe src="https://www.youtube.com/embed/rsUTitTiryc" title="{{presskit.trailer}} - Vem, Exu" frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      </figure>
      <div class="pk-video-actions">
        <button data-download="trailer">{{presskit.download_btn}}</button>
      </div>
    </section>

    <section id="sobre-o-jogo" class="pk-section" aria-labelledby="sobre-titulo">
      <header class="pk-section-heading">
        <h2 id="sobre-titulo">{{presskit.nav_about}}</h2>
      </header>

      <p>
        {{{presskit.about_desc}}}
      </p>

    </section>

    <section id="diferencial" class="pk-section" aria-labelledby="diferencial-titulo">
      <header class="pk-section-heading">
        <h2 id="diferencial-titulo">{{presskit.why_matters_title}}</h2>
      </header>



      <p>
        {{{presskit.why_matters_desc}}}
      </p>

      <ul class="pk-bullet-columns">
        <li>{{presskit.why_matters_1}}</li>
        <li>{{presskit.why_matters_2}}</li>
        <li>{{presskit.why_matters_3}}</li>
        <li>{{presskit.why_matters_4}}</li>
        <li>{{presskit.why_matters_5}}</li>
      </ul>
    </section>

    <section id="jogabilidade" class="pk-section" aria-labelledby="jogabilidade-titulo">
      <header class="pk-section-heading">
        <h2 id="jogabilidade-titulo">{{presskit.gameplay_title}}</h2>
      </header>
      <p>{{presskit.gameplay_desc}}</p>

      <ul>
        <li>{{presskit.gameplay_1}}</li>
        <li>{{presskit.gameplay_2}}</li>
        <li>{{presskit.gameplay_3}}</li>
        <li>{{presskit.gameplay_4}}</li>
        <li>{{presskit.gameplay_5}}</li>
      </ul>

      <p>{{presskit.gameplay_conclusion}}</p>
    </section>

    <section id="para-publicacao" class="pk-section" aria-labelledby="publicacao-titulo">
      <header class="pk-section-heading">
        <h2 id="publicacao-titulo">{{presskit.nav_publish}}</h2>
      </header>
      <p class="pk-caption" style="margin-bottom: 1rem;">{{presskit.publish_caption}}</p>

      <h3>{{presskit.publish_short_title}}</h3>
      <p>{{presskit.publish_short_desc}}</p>

      <h3>{{presskit.publish_medium_title}}</h3>
      <p>{{{presskit.publish_medium_desc}}}</p>

      <h3>{{presskit.publish_long_title}}</h3>
      <p>{{{presskit.publish_long_p1}}}</p>
      <p>{{{presskit.publish_long_p2}}}</p>
      <p>{{{presskit.publish_long_p3}}}</p>

      <h3>{{presskit.what_saying}}</h3>
      <div class="pk-quotes-grid">
        <blockquote class="pk-card-accent">
          <p>{{presskit.quote_1}}</p>
          <cite>{{presskit.quote_1_cite}}</cite>
        </blockquote>

        <blockquote class="pk-card-accent">
          <p>{{presskit.quote_2}}</p>
          <cite>{{presskit.quote_2_cite}}</cite>
        </blockquote>
      </div>
    </section>

    <section id="media" class="pk-section" aria-labelledby="media-titulo">
      <header class="pk-section-heading">
        <h2 id="media-titulo">{{presskit.nav_media}}</h2>
      </header>



